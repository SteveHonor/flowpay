# Backend
PORT=8080
# Deixe vazio para usar repositório em memória; preencha para usar Postgres.
DATABASE_URL=postgres://flowpay:flowpay@localhost:5432/flowpay?sslmode=disable
# Origens permitidas para CORS (dev: http://localhost:3000, prod: URL real do frontend)
ALLOWED_ORIGINS=http://localhost:3000
# Requisições por segundo por IP
RATE_LIMIT_RPS=10
# Burst máximo do token bucket 
RATE_LIMIT_BURST=30
